# ── Supabase (required) ──
# Get these from your Supabase project: Settings → API
VITE_SUPABASE_URL=https://YOUR_PROJECT_ID.supabase.co
VITE_SUPABASE_ANON_KEY=YOUR_ANON_KEY

# ── OpenAI image generation (/ai-assets) — server proxy only ──
# Set OPENAI_API_KEY in server/.env (never in the frontend).
# Point the Vite app at the image API (dev-server.js or main API on 3001).
VITE_AI_IMAGE_GEN_URL=http://localhost:3001/api/generate-image

# ── Core AI Backend ──
# The Gemini API key lives in server/.env (never in the frontend).
# See server/.env.example for backend configuration.

# ── UXsniff (optional, production only) ──
# Set to "true" to load UXsniff tracking script. Ignored on localhost.
# VITE_ENABLE_UX_SNIFF=true

# ── Microsoft Clarity (optional, production only) ──
# Set to "true" to load Clarity session-replay script. Ignored on localhost.
# VITE_ENABLE_CLARITY=true

# ── Optional: Legacy LLM settings (deprecated) ──
# VITE_LLM_API_ENDPOINT=/api/llm
# VITE_LLM_ENABLED=false
